# ============================================================
# 墨境 MOJING · 环境变量样例
# 复制本文件为 .env 并填入真实 Key
# ------------------------------------------------------------
# 不配置任何 Key 也能运行：后端自动降级到 Mock 模式
# ============================================================

# ───── 服务配置 ─────
PORT=8787
NODE_ENV=development
# 前端通过 Vite proxy 走 /api，CORS 默认允许所有

# ───── LLM 文本生成 Provider ─────
# 选择默认 LLM Provider（不填则用第一个有 Key 的）
LLM_PROVIDER=openai

# OpenAI / Azure OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# 智谱 GLM
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4-plus

# 阿里通义千问 (DashScope 兼容模式)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Moonshot Kimi
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=moonshot-v1-8k

# ───── 图片生成 Provider ─────
IMG_PROVIDER=openai

# OpenAI DALL-E 3
OPENAI_IMG_MODEL=dall-e-3
OPENAI_IMG_SIZE=1024x1024
OPENAI_IMG_QUALITY=standard

# Stability AI (Stable Diffusion)
STABILITY_API_KEY=
STABILITY_BASE_URL=https://api.stability.ai/v1
STABILITY_MODEL=stable-diffusion-xl-1024-v1-0

# 智谱 CogView
ZHIPU_IMG_MODEL=cogview-3

# 火山方舟（字节即梦/Seedream）
VOLCENGINE_API_KEY=
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_IMG_MODEL=seedream-v3-0

# ───── Mock 兜底 ─────
# 当所选 Provider 未配置 Key 时，自动走 Mock
MOCK_FALLBACK=true
